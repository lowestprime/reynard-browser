+#ifndef NSIOSNETWORKLINKSERVICE_H_
+#define NSIOSNETWORKLINKSERVICE_H_
+
+#include "mozilla/Mutex.h"
+#include "mozilla/net/DNS.h"
+#include "nsIObserver.h"
+#include "nsINetworkLinkService.h"
+#include "nsString.h"
+#include "nsTArray.h"
+
+#include <Network/Network.h>
+#include <dispatch/dispatch.h>
+
+class nsIOSNetworkLinkService final : public nsINetworkLinkService,
+                                      public nsIObserver {
+ public:
+  NS_DECL_THREADSAFE_ISUPPORTS
+  NS_DECL_NSINETWORKLINKSERVICE
+  NS_DECL_NSIOBSERVER
+
+  nsIOSNetworkLinkService();
+
+  nsresult Init();
+  nsresult Shutdown();
+
+  struct PathState {
+    bool mLinkUp = true;
+    bool mStatusKnown = false;
+    bool mExpensive = false;
+    bool mConstrained = false;
+    bool mHasIPv4 = false;
+    bool mHasIPv6 = false;
+    bool mVPNDetected = false;
+    bool mProxyDetected = false;
+    uint32_t mLinkType = nsINetworkLinkService::LINK_TYPE_UNKNOWN;
+    nsCString mNetworkID;
+  };
+
+ private:
+  virtual ~nsIOSNetworkLinkService();
+
+  void ProcessPathUpdate(nw_path_t aPath);
+  nsCString NetworkIDForPath(nw_path_t aPath, PathState& aState);
+  bool VPNDetectedForPath(nw_path_t aPath);
+  bool ProxyDetected();
+  void UpdateDNSConfig();
+  void NotifyObservers(const char* aTopic, const char* aData);
+
+  mozilla::Mutex mMutex;
+  PathState mState MOZ_GUARDED_BY(mMutex);
+  nsTArray<nsCString> mDNSSuffixList MOZ_GUARDED_BY(mMutex);
+  nsTArray<mozilla::net::NetAddr> mResolvers MOZ_GUARDED_BY(mMutex);
+
+  nw_path_monitor_t mMonitor = nullptr;
+  nw_path_t mPath = nullptr;
+  dispatch_queue_t mQueue = nullptr;
+};
+
+#endif  // NSIOSNETWORKLINKSERVICE_H_
