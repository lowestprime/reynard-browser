+nsresult nsIOSNetworkLinkService::Init() {
+  nsresult rv;
+  nsCOMPtr<nsIObserverService> observerService =
+      mozilla::services::GetObserverService();
+  if (!observerService) {
+    return NS_ERROR_FAILURE;
+  }
+
+  rv = observerService->AddObserver(this, "xpcom-shutdown", false);
+  NS_ENSURE_SUCCESS(rv, rv);
+
+  mQueue = dispatch_queue_create("org.mozilla.network-link-service.ios",
+                                 DISPATCH_QUEUE_SERIAL);
+  if (!mQueue) {
+    return NS_ERROR_FAILURE;
+  }
+
+  mMonitor = nw_path_monitor_create();
+  if (!mMonitor) {
+    return NS_ERROR_FAILURE;
+  }
+
+  RefPtr<nsIOSNetworkLinkService> self = this;
+  nw_path_monitor_set_update_handler(mMonitor, ^(nw_path_t aPath) {
+    nw_path_t retainedPath = static_cast<nw_path_t>(nw_retain(aPath));
+    bool shouldProcess = false;
+    {
+      MutexAutoLock lock(self->mMutex);
+      shouldProcess =
+          !self->mPath || !nw_path_is_equal(self->mPath, retainedPath);
+      if (shouldProcess) {
+        if (self->mPath) {
+          nw_release(self->mPath);
+        }
+        self->mPath = retainedPath;
+      }
+    }
+
+    if (shouldProcess) {
+      self->ProcessPathUpdate(retainedPath);
+    } else {
+      nw_release(retainedPath);
+    }
+  });
+
+  nw_path_monitor_set_queue(mMonitor, mQueue);
+  nw_path_monitor_start(mMonitor);
+  return NS_OK;
+}
+
+nsresult nsIOSNetworkLinkService::Shutdown() {
+  nsCOMPtr<nsIObserverService> observerService =
+      mozilla::services::GetObserverService();
+  if (observerService) {
+    observerService->RemoveObserver(this, "xpcom-shutdown");
+  }
+
+  if (mMonitor) {
+    nw_path_monitor_cancel(mMonitor);
+    nw_release(mMonitor);
+    mMonitor = nullptr;
+  }
+
+  {
+    MutexAutoLock lock(mMutex);
+    if (mPath) {
+      nw_release(mPath);
+      mPath = nullptr;
+    }
+  }
+
+  if (mQueue) {
+    dispatch_release(mQueue);
+    mQueue = nullptr;
+  }
+
+  return NS_OK;
+}
+
+void nsIOSNetworkLinkService::NotifyObservers(const char* aTopic,
+                                              const char* aData) {
+  MOZ_ASSERT(NS_IsMainThread());
+
+  LOG(("nsIOSNetworkLinkService::NotifyObservers: topic:%s data:%s\n", aTopic,
+       aData ? aData : ""));
+
+  nsCOMPtr<nsIObserverService> observerService =
+      mozilla::services::GetObserverService();
+  if (observerService) {
+    observerService->NotifyObservers(
+        static_cast<nsINetworkLinkService*>(this), aTopic,
+        aData ? NS_ConvertASCIItoUTF16(aData).get() : nullptr);
+  }
+}
