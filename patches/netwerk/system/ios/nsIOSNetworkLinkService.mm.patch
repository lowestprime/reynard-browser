+void nsIOSNetworkLinkService::UpdateDNSConfig() {
+  nsTArray<nsCString> suffixes;
+  nsTArray<mozilla::net::NetAddr> resolvers;
+
+  struct __res_state res;
+  if (res_ninit(&res) == 0) {
+    for (int i = 0; i < MAXDNSRCH; i++) {
+      if (!res.dnsrch[i]) {
+        break;
+      }
+      suffixes.AppendElement(nsCString(res.dnsrch[i]));
+    }
+
+    for (int i = 0; i < res.nscount; i++) {
+      AppendResolver(resolvers,
+                     reinterpret_cast<const sockaddr*>(&res.nsaddr_list[i]));
+    }
+    res_ndestroy(&res);
+  }
+
+  bool suffixesChanged = false;
+  {
+    MutexAutoLock lock(mMutex);
+    suffixesChanged = mDNSSuffixList != suffixes;
+    mDNSSuffixList = std::move(suffixes);
+    mResolvers = std::move(resolvers);
+  }
+
+  if (suffixesChanged) {
+    RefPtr<nsIOSNetworkLinkService> self = this;
+    NS_DispatchToMainThread(NS_NewRunnableFunction(
+        "nsIOSNetworkLinkService::UpdateDNSConfig", [self]() {
+          self->NotifyObservers(NS_DNS_SUFFIX_LIST_UPDATED_TOPIC, nullptr);
+        }));
+  }
+}
