+void nsIOSNetworkLinkService::ProcessPathUpdate(nw_path_t aPath) {
+  PathState newState;
+  nw_path_status_t status = nw_path_get_status(aPath);
+  newState.mStatusKnown = status != nw_path_status_invalid;
+  newState.mLinkUp = status == nw_path_status_satisfied;
+  newState.mExpensive = nw_path_is_expensive(aPath);
+  newState.mConstrained = nw_path_is_constrained(aPath);
+  newState.mHasIPv4 = nw_path_has_ipv4(aPath);
+  newState.mHasIPv6 = nw_path_has_ipv6(aPath);
+  newState.mVPNDetected = VPNDetectedForPath(aPath);
+  newState.mProxyDetected =
+      StaticPrefs::network_notify_checkForProxies() && ProxyDetected();
+  newState.mLinkType = LinkTypeForPath(aPath);
+  sHasNonLocalIPv6 = newState.mHasIPv6;
+  if (newState.mLinkUp) {
+    newState.mNetworkID = NetworkIDForPath(aPath, newState);
+  }
+
+  bool firstUpdate = false;
+  bool linkChanged = false;
+  bool pathChanged = false;
+  bool linkTypeChanged = false;
+  bool networkIDChanged = false;
+  {
+    MutexAutoLock lock(mMutex);
+    firstUpdate = !mState.mStatusKnown;
+    linkChanged = mState.mLinkUp != newState.mLinkUp ||
+                  mState.mStatusKnown != newState.mStatusKnown;
+    pathChanged = mState.mExpensive != newState.mExpensive ||
+                  mState.mConstrained != newState.mConstrained ||
+                  mState.mHasIPv4 != newState.mHasIPv4 ||
+                  mState.mHasIPv6 != newState.mHasIPv6 ||
+                  mState.mVPNDetected != newState.mVPNDetected ||
+                  mState.mProxyDetected != newState.mProxyDetected ||
+                  mState.mLinkType != newState.mLinkType ||
+                  mState.mNetworkID != newState.mNetworkID;
+    linkTypeChanged = mState.mLinkType != newState.mLinkType;
+    networkIDChanged = mState.mNetworkID != newState.mNetworkID;
+    mState = newState;
+  }
+
+  UpdateDNSConfig();
+
+  RefPtr<nsIOSNetworkLinkService> self = this;
+  if (linkChanged) {
+    const char* data = nullptr;
+    if (!newState.mStatusKnown) {
+      data = NS_NETWORK_LINK_DATA_UNKNOWN;
+    } else {
+      data = newState.mLinkUp ? NS_NETWORK_LINK_DATA_UP
+                              : NS_NETWORK_LINK_DATA_DOWN;
+    }
+    NS_DispatchToMainThread(NS_NewRunnableFunction(
+        "nsIOSNetworkLinkService::ProcessPathUpdate link", [self, data]() {
+          self->NotifyObservers(NS_NETWORK_LINK_TOPIC, data);
+        }));
+  } else if (!firstUpdate && pathChanged &&
+             StaticPrefs::network_notify_changed()) {
+    NS_DispatchToMainThread(NS_NewRunnableFunction(
+        "nsIOSNetworkLinkService::ProcessPathUpdate path", [self]() {
+          self->NotifyObservers(NS_NETWORK_LINK_TOPIC,
+                                NS_NETWORK_LINK_DATA_CHANGED);
+        }));
+  }
+
+  if (!firstUpdate && linkTypeChanged) {
+    const char* data = NS_NETWORK_LINK_TYPE_UNKNOWN;
+    if (newState.mLinkType == nsINetworkLinkService::LINK_TYPE_WIFI) {
+      data = NS_NETWORK_LINK_TYPE_WIFI;
+    } else if (newState.mLinkType == nsINetworkLinkService::LINK_TYPE_MOBILE) {
+      data = NS_NETWORK_LINK_TYPE_MOBILE;
+    } else if (newState.mLinkType ==
+               nsINetworkLinkService::LINK_TYPE_ETHERNET) {
+      data = NS_NETWORK_LINK_TYPE_ETHERNET;
+    }
+
+    NS_DispatchToMainThread(NS_NewRunnableFunction(
+        "nsIOSNetworkLinkService::ProcessPathUpdate link type", [self, data]() {
+          self->NotifyObservers(NS_NETWORK_LINK_TYPE_TOPIC, data);
+        }));
+  }
+
+  if (!firstUpdate && networkIDChanged) {
+    NS_DispatchToMainThread(NS_NewRunnableFunction(
+        "nsIOSNetworkLinkService::ProcessPathUpdate network id", [self]() {
+          self->NotifyObservers(NS_NETWORK_ID_CHANGED_TOPIC, nullptr);
+        }));
+  }
+}
