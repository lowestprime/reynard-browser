+static uint32_t LinkTypeForPath(nw_path_t aPath) {
+  if (nw_path_uses_interface_type(aPath, nw_interface_type_wifi)) {
+    return nsINetworkLinkService::LINK_TYPE_WIFI;
+  }
+  if (nw_path_uses_interface_type(aPath, nw_interface_type_cellular)) {
+    return nsINetworkLinkService::LINK_TYPE_MOBILE;
+  }
+  if (nw_path_uses_interface_type(aPath, nw_interface_type_wired)) {
+    return nsINetworkLinkService::LINK_TYPE_ETHERNET;
+  }
+
+  return nsINetworkLinkService::LINK_TYPE_UNKNOWN;
+}
+
+static void HashCString(SHA1Sum& aSHA1, const nsCString& aValue) {
+  aSHA1.update(aValue.get(), aValue.Length());
+}
+
+nsCString nsIOSNetworkLinkService::NetworkIDForPath(nw_path_t aPath,
+                                                    PathState& aState) {
+  auto hashKeys = MakeUnique<std::vector<nsCString>>();
+  auto* hashKeysPtr = hashKeys.get();
+
+  nw_path_enumerate_interfaces(aPath, ^bool(nw_interface_t aInterface) {
+    nsAutoCString key;
+    const char* name = nw_interface_get_name(aInterface);
+    key.AppendPrintf("%s:%u:%u", name ? name : "",
+                     nw_interface_get_index(aInterface),
+                     nw_interface_get_type(aInterface));
+    hashKeysPtr->push_back(std::move(key));
+    return true;
+  });
+
+  nw_path_enumerate_gateways(aPath, ^bool(nw_endpoint_t aGateway) {
+    char* address = nw_endpoint_copy_address_string(aGateway);
+    if (address) {
+      nsAutoCString key("gateway:"_ns);
+      key.Append(address);
+      hashKeysPtr->push_back(std::move(key));
+      free(address);
+    } else {
+      const char* hostname = nw_endpoint_get_hostname(aGateway);
+      if (!hostname) {
+        return true;
+      }
+      nsAutoCString key("gateway:"_ns);
+      key.Append(hostname);
+      hashKeysPtr->push_back(std::move(key));
+    }
+    return true;
+  });
+
+  if (hashKeys->empty()) {
+    return ""_ns;
+  }
+
+  hashKeys->push_back(nsPrintfCString("ipv4:%d", aState.mHasIPv4));
+  hashKeys->push_back(nsPrintfCString("ipv6:%d", aState.mHasIPv6));
+  hashKeys->push_back(nsPrintfCString("expensive:%d", aState.mExpensive));
+  hashKeys->push_back(nsPrintfCString("constrained:%d", aState.mConstrained));
+  hashKeys->push_back(nsPrintfCString("type:%u", aState.mLinkType));
+  std::sort(hashKeys->begin(), hashKeys->end());
+
+  SHA1Sum sha1;
+  SeedNetworkId(sha1);
+  for (const auto& key : *hashKeys) {
+    HashCString(sha1, key);
+  }
+
+  uint8_t digest[SHA1Sum::kHashSize];
+  sha1.finish(digest);
+
+  nsAutoCString digestString(reinterpret_cast<char*>(digest),
+                             SHA1Sum::kHashSize);
+  nsAutoCString output;
+  nsresult rv = Base64Encode(digestString, output);
+  MOZ_RELEASE_ASSERT(NS_SUCCEEDED(rv));
+  return output;
+}
+
+bool nsIOSNetworkLinkService::VPNDetectedForPath(nw_path_t aPath) {
+  __block bool vpnDetected = false;
+  nw_path_enumerate_interfaces(aPath, ^bool(nw_interface_t aInterface) {
+    const char* name = nw_interface_get_name(aInterface);
+    if (!name) {
+      return true;
+    }
+
+    if (!strncmp(name, "tap", 3) || !strncmp(name, "tun", 3) ||
+        !strncmp(name, "ppp", 3) || !strncmp(name, "ipsec", 5) ||
+        !strncmp(name, "utun", 4)) {
+      vpnDetected = true;
+      return false;
+    }
+
+    return true;
+  });
+
+  return vpnDetected;
+}
+
+static bool ProxySettingEnabled(CFDictionaryRef aSettings, CFStringRef aKey) {
+  CFTypeRef value = CFDictionaryGetValue(aSettings, aKey);
+  if (!value) {
+    return false;
+  }
+
+  CFTypeID type = CFGetTypeID(value);
+  if (type == CFNumberGetTypeID()) {
+    int enabled = 0;
+    return CFNumberGetValue(static_cast<CFNumberRef>(value), kCFNumberIntType,
+                            &enabled) &&
+           enabled != 0;
+  }
+
+  if (type == CFBooleanGetTypeID()) {
+    return CFBooleanGetValue(static_cast<CFBooleanRef>(value));
+  }
+
+  return false;
+}
+
+bool nsIOSNetworkLinkService::ProxyDetected() {
+  CFDictionaryRef settings = CFNetworkCopySystemProxySettings();
+  if (!settings) {
+    return false;
+  }
+
+  bool detected =
+      ProxySettingEnabled(settings, kCFNetworkProxiesHTTPEnable) ||
+      ProxySettingEnabled(settings, kCFNetworkProxiesProxyAutoConfigEnable);
+  CFRelease(settings);
+
+  return detected;
+}
+
+static void AppendResolver(nsTArray<mozilla::net::NetAddr>& aResolvers,
+                           const sockaddr* aAddress) {
+  if (!aAddress) {
+    return;
+  }
+
+  mozilla::net::NetAddr addr{};
+  if (aAddress->sa_family == AF_INET) {
+    const auto* sin = reinterpret_cast<const struct sockaddr_in*>(aAddress);
+    addr.inet.family = AF_INET;
+    addr.inet.port = sin->sin_port;
+    addr.inet.ip = sin->sin_addr.s_addr;
+  } else if (aAddress->sa_family == AF_INET6) {
+    const auto* sin6 = reinterpret_cast<const struct sockaddr_in6*>(aAddress);
+    addr.inet6.family = AF_INET6;
+    addr.inet6.port = sin6->sin6_port;
+    addr.inet6.flowinfo = sin6->sin6_flowinfo;
+    memcpy(&addr.inet6.ip, &sin6->sin6_addr, sizeof(addr.inet6.ip.u8));
+    addr.inet6.scope_id = sin6->sin6_scope_id;
+  } else {
+    return;
+  }
+
+  if (!aResolvers.Contains(addr)) {
+    aResolvers.AppendElement(addr);
+  }
+}
