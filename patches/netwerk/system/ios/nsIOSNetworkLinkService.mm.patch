+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetIsLinkUp(bool* aIsUp) {
+  MutexAutoLock lock(mMutex);
+  *aIsUp = mState.mLinkUp;
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetLinkStatusKnown(bool* aIsKnown) {
+  MutexAutoLock lock(mMutex);
+  *aIsKnown = mState.mStatusKnown;
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetLinkType(uint32_t* aLinkType) {
+  NS_ENSURE_ARG_POINTER(aLinkType);
+
+  MutexAutoLock lock(mMutex);
+  *aLinkType = mState.mLinkType;
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetNetworkID(nsACString& aNetworkID) {
+  MutexAutoLock lock(mMutex);
+  aNetworkID = mState.mNetworkID;
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetDnsSuffixList(nsTArray<nsCString>& aDnsSuffixList) {
+  MutexAutoLock lock(mMutex);
+  aDnsSuffixList.Clear();
+  aDnsSuffixList.AppendElements(mDNSSuffixList);
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetNativeResolvers(
+    nsTArray<mozilla::net::NetAddr>& aResolvers) {
+  MutexAutoLock lock(mMutex);
+  aResolvers.Clear();
+  aResolvers.AppendElements(mResolvers);
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetResolvers(
+    nsTArray<RefPtr<nsINetAddr>>& aResolvers) {
+  nsTArray<mozilla::net::NetAddr> addresses;
+  nsresult rv = GetNativeResolvers(addresses);
+  if (NS_FAILED(rv)) {
+    return rv;
+  }
+
+  aResolvers.Clear();
+  for (const auto& addr : addresses) {
+    aResolvers.AppendElement(MakeRefPtr<nsNetAddr>(&addr));
+  }
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::GetPlatformDNSIndications(
+    uint32_t* aPlatformDNSIndications) {
+  NS_ENSURE_ARG_POINTER(aPlatformDNSIndications);
+
+  bool proxyDetected =
+      StaticPrefs::network_notify_checkForProxies() && ProxyDetected();
+  MutexAutoLock lock(mMutex);
+  mState.mProxyDetected = proxyDetected;
+  uint32_t indications = nsINetworkLinkService::NONE_DETECTED;
+  if (mState.mVPNDetected) {
+    indications |= nsINetworkLinkService::VPN_DETECTED;
+  }
+  if (mState.mProxyDetected) {
+    indications |= nsINetworkLinkService::PROXY_DETECTED;
+  }
+  *aPlatformDNSIndications = indications;
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsIOSNetworkLinkService::Observe(nsISupports* aSubject, const char* aTopic,
+                                 const char16_t* aData) {
+  if (!strcmp(aTopic, "xpcom-shutdown")) {
+    Shutdown();
+  }
+
+  return NS_OK;
+}
